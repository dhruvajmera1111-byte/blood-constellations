def main():
    try:
        with open('admin.js', 'r', encoding='utf-8') as f:
            content = f.read()

        js_append = """
  /* ----------------------------------------------------------
     DRAG AND DROP UPLOADS
  ---------------------------------------------------------- */
  const dropZones = document.querySelectorAll('.drop-zone');
  
  dropZones.forEach(zone => {
    const fileInput = zone.querySelector('input[type="file"]');
    const hiddenInput = zone.querySelector('input[type="hidden"]');
    const previewImg = zone.querySelector('.preview-img');
    const dropText = zone.querySelector('.drop-text');

    // Click to upload
    zone.addEventListener('click', () => fileInput.click());

    // Drag events
    zone.addEventListener('dragover', (e) => {
      e.preventDefault();
      zone.classList.add('drag-over');
    });
    zone.addEventListener('dragleave', () => {
      zone.classList.remove('drag-over');
    });
    zone.addEventListener('drop', (e) => {
      e.preventDefault();
      zone.classList.remove('drag-over');
      if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        handleUpload(e.dataTransfer.files[0], zone, hiddenInput, previewImg, dropText);
      }
    });

    // File input change
    fileInput.addEventListener('change', (e) => {
      if (e.target.files && e.target.files.length > 0) {
        handleUpload(e.target.files[0], zone, hiddenInput, previewImg, dropText);
      }
    });
  });

  async function handleUpload(file, zone, hiddenInput, previewImg, dropText) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload an image file.');
      return;
    }

    dropText.textContent = 'Uploading...';
    
    try {
      const res = await fetch('/upload?filename=' + encodeURIComponent(file.name), {
        method: 'POST',
        body: file
      });
      const data = await res.json();
      
      if (data.success) {
        hiddenInput.value = data.path;
        previewImg.src = data.path;
        previewImg.style.display = 'block';
        dropText.style.display = 'none';
      } else {
        alert('Upload failed.');
        dropText.textContent = 'Drag & Drop or Click';
      }
    } catch (err) {
      console.error('Upload error', err);
      alert('Error uploading file. Make sure server.py is running.');
      dropText.textContent = 'Drag & Drop or Click';
    }
  }

  // Update populateHomeSettings to also show previews
  const oldPopulate = populateHomeSettings;
  populateHomeSettings = function() {
    oldPopulate();
    dropZones.forEach(zone => {
      const hiddenInput = zone.querySelector('input[type="hidden"]');
      const previewImg = zone.querySelector('.preview-img');
      const dropText = zone.querySelector('.drop-text');
      if (hiddenInput && hiddenInput.value) {
        previewImg.src = hiddenInput.value;
        previewImg.style.display = 'block';
        dropText.style.display = 'none';
      }
    });
  };
"""

        # We will insert this at the end, right before the IIFE closing `})();`
        content = content.replace('checkAuth();\n\n  // Populate home settings', js_append + '\n  checkAuth();\n\n  // Populate home settings')
        
        with open('admin.js', 'w', encoding='utf-8') as f:
            f.write(content)
            
        print("Updated admin.js")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == '__main__':
