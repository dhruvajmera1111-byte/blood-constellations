    dzGallery.addEventListener('dragover', (e) => {
      e.preventDefault();
      dzGallery.classList.add('drag-over');
    });
    dzGallery.addEventListener('dragleave', () => {
      dzGallery.classList.remove('drag-over');
    });
    dzGallery.addEventListener('drop', (e) => {
      e.preventDefault();
      dzGallery.classList.remove('drag-over');
      if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        handleGalleryUpload(e.dataTransfer.files[0], dropText);
      }
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files && e.target.files.length > 0) {
        handleGalleryUpload(e.target.files[0], dropText);
      }
    });
  }

  async function handleGalleryUpload(file, dropText) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload an image file.');
      return;
    }

    const origText = dropText.textContent;
    dropText.textContent = 'Uploading...';
    
    try {
      const res = await fetch('/upload?filename=' + encodeURIComponent(file.name), {
        method: 'POST',
        body: file
      });
      const data = await res.json();
      
      if (data.success) {
        let gallery = window.Store.getHomeGallery();
        gallery.push(data.path);
        window.Store.saveHomeGallery(gallery);
        renderAdminGallery();
      if (typeof populateContactSettings === 'function') populateContactSettings();
      } else {
        alert('Upload failed.');
      }
    } catch (err) {
      console.error('Upload error', err);
      alert('Error uploading file.');
    } finally {
      dropText.textContent = origText;
    }
  }

  window.deleteGalleryImage = function(index) {
    if (confirm('Remove this image from the gallery?')) {
      let gallery = window.Store.getHomeGallery();
      gallery.splice(index, 1);
      window.Store.saveHomeGallery(gallery);
      renderAdminGallery();
      if (typeof populateContactSettings === 'function') populateContactSettings();
    }
  };

  function renderAdminGallery() {
    if (!galleryGrid) return;
    const gallery = window.Store.getHomeGallery();
    galleryGrid.innerHTML = '';
    gallery.forEach((url, i) => {
      const item = document.createElement('div');
      item.style.position = 'relative';
      item.style.border = '1px solid rgba(255,255,255,0.1)';
      item.style.borderRadius = '4px';
      item.style.overflow = 'hidden';
      item.innerHTML = `
        <img src="${url}" style="width: 100%; height: 100px; object-fit: cover; display: block;" />
        <button type="button" class="btn-delete-product danger" style="position: absolute; top: 5px; right: 5px; padding: 0.2rem 0.5rem; font-size: 0.7rem;" onclick="deleteGalleryImage(${i})">X</button>
      `;
      galleryGrid.appendChild(item);
    });
  }

  
  /* ----------------------------------------------------------
     CONTACT INFO MANAGEMENT
  ---------------------------------------------------------- */
  function populateContactSettings() {
    const mobileInput = document.getElementById('contact-mobile');
    if (!mobileInput) return;
    
    const info = window.Store.getContactInfo();
    mobileInput.value = info.mobile || '';
  }

  const contactForm = document.getElementById('contact-settings-form');
  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const mobile = document.getElementById('contact-mobile').value.trim();
      
      window.Store.saveContactInfo({ mobile });
      alert('Contact info saved successfully!');
    });
  }

  // Removed MutationObserver
})();

/* ============================================================
   WAR OF BLOOD — JavaScript
   ============================================================ */

(function () {
  'use strict';

  /* ----------------------------------------------------------
     CURSOR TRACKER
  ---------------------------------------------------------- */
  document.addEventListener('mousemove', (e) => {
    document.body.style.setProperty('--cx', e.clientX + 'px');
    document.body.style.setProperty('--cy', e.clientY + 'px');
  });

  /* ----------------------------------------------------------
     INTRO SPLASH
  ---------------------------------------------------------- */
  const INTRO_DURATION = 9000; // total ms
  const SLIDE_DURATION = 3000;  // ms per slide

  const splash        = document.getElementById('intro-splash');
  const mainSite      = document.getElementById('main-site');
  const progressBar   = document.getElementById('intro-progress-bar');
  const skipBtn       = document.getElementById('skip-intro');
  const slides        = document.querySelectorAll('.intro-slide');
  const dripsContainer= document.getElementById('blood-drips');

  let currentSlide  = 0;
  let slideInterval = null;
  let progressTimer = null;
  let startTime     = null;

  // Generate blood drip elements
  function createBloodDrips() {
    const count = 8;
    for (let i = 0; i < count; i++) {
      const drip = document.createElement('div');
      drip.classList.add('blood-drip');
      const h = 30 + Math.random() * 50;
      drip.style.setProperty('--h', h + 'px');
      drip.style.setProperty('--dur', (1.2 + Math.random() * 0.8) + 's');
      drip.style.setProperty('--delay', (0.5 + Math.random() * 1.5) + 's');
      dripsContainer.appendChild(drip);
    }
  }
  createBloodDrips();

  // Advance to next slide
  function goToSlide(idx) {
    slides[currentSlide].classList.remove('active');
    // Reset caption animation
    const prevCaption = slides[currentSlide].querySelector('.slide-caption');
    if (prevCaption) {
      prevCaption.style.animation = 'none';
      prevCaption.offsetHeight; // force reflow
    }
    currentSlide = idx % slides.length;
    slides[currentSlide].classList.add('active');
    // Restart caption animation
    const newCaption = slides[currentSlide].querySelector('.slide-caption');
    if (newCaption) {
      newCaption.style.animation = '';
    }
  }

  // Animate progress bar
  function animateProgress() {
    startTime = performance.now();
    function tick(now) {
      const elapsed = now - startTime;
      const pct = Math.min((elapsed / INTRO_DURATION) * 100, 100);
      progressBar.style.width = pct + '%';
      if (elapsed < INTRO_DURATION) {
        progressTimer = requestAnimationFrame(tick);
      }
    }
    progressTimer = requestAnimationFrame(tick);
  }

  // Start intro slideshow
  function startIntro() {
    animateProgress();
    slideInterval = setInterval(() => {
      goToSlide(currentSlide + 1);
    }, SLIDE_DURATION);

    // Auto-end intro after INTRO_DURATION
    setTimeout(endIntro, INTRO_DURATION);
  }

  // End intro & reveal main site
  function endIntro() {
    clearInterval(slideInterval);
    cancelAnimationFrame(progressTimer);
    progressBar.style.width = '100%';

    splash.style.transition = 'opacity 1s ease';
    splash.style.opacity = '0';
    splash.style.pointerEvents = 'none';

    mainSite.classList.remove('hidden');
    mainSite.style.opacity = '0';
    setTimeout(() => {
      mainSite.style.transition = 'opacity 0.8s ease';
      mainSite.style.opacity = '1';
      splash.style.display = 'none';
    }, 800);

    // Trigger initial scroll animations
    setTimeout(checkScrollAnimations, 200);
  }

  skipBtn.addEventListener('click', endIntro);
  startIntro();

  /* ----------------------------------------------------------
     PARTICLES
  ---------------------------------------------------------- */
  function createParticles() {
    const field = document.getElementById('particle-field');
    if (!field) return;
    const colors = [
      'rgba(139,0,0,0.6)',
      'rgba(255,107,0,0.5)',
      'rgba(123,92,255,0.4)',
      'rgba(201,168,76,0.4)',
      'rgba(204,0,0,0.5)',
    ];
    for (let i = 0; i < 40; i++) {
      const p = document.createElement('div');
      p.classList.add('particle');
      const size = 2 + Math.random() * 5;
      const color = colors[Math.floor(Math.random() * colors.length)];
      const dur = 6 + Math.random() * 12;
      const delay = -(Math.random() * dur);
      const x = Math.random() * 100;
      const y = Math.random() * 100;
      const tx = (Math.random() - 0.5) * 60;
      const ty = -(20 + Math.random() * 80);
      const tx2 = (Math.random() - 0.5) * 40;
      const ty2 = -(60 + Math.random() * 120);
      p.style.cssText = `
        width: ${size}px; height: ${size}px;
        background: ${color};
        left: ${x}%; top: ${y}%;
        --dur: ${dur}s; --delay: ${delay}s;
        --tx: ${tx}px; --ty: ${ty}px;
        --tx2: ${tx2}px; --ty2: ${ty2}px;
        --op: ${0.3 + Math.random() * 0.7};
        box-shadow: 0 0 ${size * 3}px ${color};
        animation-delay: ${delay}s;
      `;
      field.appendChild(p);
    }
  }
  createParticles();

  /* ----------------------------------------------------------
     NAVBAR SCROLL
  ---------------------------------------------------------- */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  });

  /* ----------------------------------------------------------
     MOBILE NAV HAMBURGER
  ---------------------------------------------------------- */
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks  = document.getElementById('nav-links');
  hamburger.addEventListener('click', () => {
    navLinks.classList.toggle('open');
  });
  // Close on nav link click
  navLinks.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => navLinks.classList.remove('open'));
  });

  /* ----------------------------------------------------------
     SCROLL ANIMATIONS — IntersectionObserver
  ---------------------------------------------------------- */
  function checkScrollAnimations() {
    // Story blocks
    const storyBlocks = document.querySelectorAll('.story-block');
    const charCards   = document.querySelectorAll('.char-card');
    const statFills   = document.querySelectorAll('.stat-fill');
    const revealEls   = document.querySelectorAll('.reveal');

    const observerOpts = { threshold: 0.15 };

    const storyObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('visible');
      });
    }, observerOpts);

    storyBlocks.forEach(b => storyObs.observe(b));

    const charObs = new IntersectionObserver((entries) => {
      entries.forEach((e, idx) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add('visible'), idx * 120);
        }
      });
    }, { threshold: 0.1 });

    charCards.forEach(c => charObs.observe(c));

    // Stat bar animations
    const statObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('animated');
          statObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });

    statFills.forEach(s => statObs.observe(s));

    // Generic reveal
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });

    revealEls.forEach(el => revealObs.observe(el));
  }

  // Hero parallax
  window.addEventListener('scroll', () => {
    const heroBgImg = document.querySelector('.hero-bg-img');
    if (!heroBgImg) return;
    const scrollY = window.scrollY;
    heroBgImg.style.transform = `scale(1.05) translateY(${scrollY * 0.3}px)`;
  });

  /* ----------------------------------------------------------
     GALLERY LIGHTBOX (simple overlay)
  ---------------------------------------------------------- */
  const galleryItems = document.querySelectorAll('.gallery-item');

  function createLightbox() {
    const lb = document.createElement('div');
    lb.id = 'lightbox';
    lb.style.cssText = `
      position: fixed; inset: 0; z-index: 99999;
      background: rgba(0,0,0,0.95);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; opacity: 0; transition: opacity 0.4s;
      backdrop-filter: blur(10px);
    `;
    const img = document.createElement('img');
    img.style.cssText = `
      max-width: 90vw; max-height: 90vh;
      object-fit: contain;
      box-shadow: 0 0 80px rgba(139,0,0,0.4);
      transform: scale(0.9); transition: transform 0.4s;
    `;
    const closeBtn = document.createElement('button');
    closeBtn.textContent = '✕';
    closeBtn.style.cssText = `
      position: absolute; top: 2rem; right: 2rem;
      background: transparent; border: 1px solid rgba(255,255,255,0.2);
      color: white; font-size: 1.2rem; width: 44px; height: 44px;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: border-color 0.3s; font-family: inherit;
    `;
    closeBtn.onmouseenter = () => closeBtn.style.borderColor = 'rgba(139,0,0,0.8)';
    closeBtn.onmouseleave = () => closeBtn.style.borderColor = 'rgba(255,255,255,0.2)';
    lb.appendChild(img);
    lb.appendChild(closeBtn);
    document.body.appendChild(lb);

    function open(src) {
      img.src = src;
      lb.style.display = 'flex';
      requestAnimationFrame(() => {
        lb.style.opacity = '1';
        img.style.transform = 'scale(1)';
      });
    }

    function close() {
      lb.style.opacity = '0';
      img.style.transform = 'scale(0.9)';
      setTimeout(() => { lb.style.display = 'none'; }, 400);
    }

    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

    return { open };
  }

  const lightbox = createLightbox();

  galleryItems.forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img');
      if (img) lightbox.open(img.src);
    });
    item.style.cursor = 'pointer';
  });

  /* ----------------------------------------------------------
     HERO TITLE GLOW PULSE
  ---------------------------------------------------------- */
  let glowIntensity = 1;
  let glowDirection = 1;

  function pulseGlow() {
    glowIntensity += 0.01 * glowDirection;
    if (glowIntensity > 1.3) glowDirection = -1;
    if (glowIntensity < 0.7) glowDirection = 1;

    const bloodEl = document.querySelector('.hero-blood');
    if (bloodEl) {
      bloodEl.style.filter = `drop-shadow(0 0 ${40 * glowIntensity}px rgba(139,0,0,${0.8 * glowIntensity}))`;
    }
    requestAnimationFrame(pulseGlow);
  }
  pulseGlow();

  /* ----------------------------------------------------------
     SMOOTH SCROLL FOR NAV LINKS
  ---------------------------------------------------------- */
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const target = document.querySelector(link.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ----------------------------------------------------------
     SECTION TITLE ENTRANCE ANIMATION
  ---------------------------------------------------------- */
  document.querySelectorAll('.section-title, .section-label').forEach(el => {
    el.classList.add('reveal');
  });

  // Run scroll check once DOM ready (also called after intro ends)
  checkScrollAnimations();

  /* ----------------------------------------------------------
     HOME PAGE IMAGES SYNC
  ---------------------------------------------------------- */
  function applyHomeImages() {
    if (!window.Store) return;
    const imgs = window.Store.getHomeImages();
    const map = {
      'img-intro-1': imgs.intro1,
      'img-intro-2': imgs.intro2,
      'img-intro-3': imgs.intro3,
      'img-hero': imgs.hero,
      'img-story-1': imgs.story1,
      'img-story-2': imgs.story2,
      'img-story-3': imgs.story3,
      'img-char-1': imgs.char1,
      'img-char-2': imgs.char2,
      'img-char-3': imgs.char3
    };

    for (const [id, url] of Object.entries(map)) {
      const el = document.getElementById(id);
      if (el && url) {
        el.src = url;
      }
    }
  }

  // Apply on load
  applyHomeImages();
  if (typeof applyHomeGallery === 'function') applyHomeGallery();
  if (typeof applyContactInfo === 'function') applyContactInfo();

  // Listen for changes from other tabs/admin panel
  window.addEventListener('bc_home_images_changed', applyHomeImages);

})();

  // ----------------------------------------------------------------
  // GALLERY DYNAMIC LOADING
  // ----------------------------------------------------------------
  function applyHomeGallery() {
    if (!window.Store) return;
    const gallerySection = document.getElementById('gallery');
    const galleryGrid = document.getElementById('dynamic-gallery-grid');
    if (!gallerySection || !galleryGrid) return;

    const gallery = window.Store.getHomeGallery();
    
    if (!gallery || gallery.length === 0) {
      gallerySection.style.display = 'none';
      return;
    }

    gallerySection.style.display = 'block';
    galleryGrid.innerHTML = '';
    
    gallery.forEach((url, i) => {
      const item = document.createElement('div');
      item.classList.add('gallery-item');
      if (i === 0 && gallery.length % 2 !== 0) {
        // Make the first item large if odd number of items for cooler grid
        item.classList.add('large');
      }
      
      item.innerHTML = `
        <img src="${url}" alt="Gallery Image ${i+1}" style="width: 100%; height: 100%; object-fit: cover;" />
        <div class="gallery-overlay">
          <span class="gallery-label">ARTWORK ${i+1}</span>
        </div>
      `;
      galleryGrid.appendChild(item);
    });
  }

  window.addEventListener('bc_home_gallery_changed', applyHomeGallery);

  // ----------------------------------------------------------------
  // CONTACT INFO DYNAMIC LOADING
  // ----------------------------------------------------------------
  function applyContactInfo() {
    if (!window.Store) return;
    const mobileEl = document.getElementById('dynamic-mobile-number');
    if (!mobileEl) return;

    const info = window.Store.getContactInfo();
    if (info && info.mobile) {
      mobileEl.textContent = info.mobile;
    }
  }

  window.addEventListener('bc_contact_info_changed', applyContactInfo);

