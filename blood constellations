    } finally {
      dropText.textContent = origText;
    }
  }

  window.deleteGalleryImage = function(index) {
    if (confirm('Remove this image from the gallery?')) {
      let gallery = window.Store.getHomeGallery();
      gallery.splice(index, 1);
      window.Store.saveHomeGallery(gallery);
      renderAdminGallery();
    }
  };

  function renderAdminGallery() {
    if (!galleryGrid) return;
    const gallery = window.Store.getHomeGallery();
    galleryGrid.innerHTML = '';
    gallery.forEach((url, i) => {
      const item = document.createElement('div');
      item.style.position = 'relative';
      item.style.border = '1px solid rgba(255,255,255,0.1)';
      item.style.borderRadius = '4px';
      item.style.overflow = 'hidden';
      item.innerHTML = `
        <img src="${url}" style="width: 100%; height: 100px; object-fit: cover; display: block;" />
        <button type="button" class="btn-delete-product danger" style="position: absolute; top: 5px; right: 5px; padding: 0.2rem 0.5rem; font-size: 0.7rem;" onclick="deleteGalleryImage(${i})">X</button>
      `;
      galleryGrid.appendChild(item);
    });
  }
"""

        # Add renderAdminGallery() to checkAuth()
        content = content.replace(
            'populateHomeSettings();\n      }',
            'populateHomeSettings();\n      }\n      if (typeof renderAdminGallery === \'function\') renderAdminGallery();'
        )

        # We will insert this at the end, right before the IIFE closing `})();`
        content = content.replace('// Removed MutationObserver\n})();', js_append + '\n  // Removed MutationObserver\n})();')
        
        with open('admin.js', 'w', encoding='utf-8') as f:
            f.write(content)
            
        print("Updated admin.js")
    except Exception as e:
