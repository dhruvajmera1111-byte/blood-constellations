import re

def main():
    try:
        with open('admin.html', 'r', encoding='utf-8') as f:
            content = f.read()

        # Find the Home Page Settings section
        start_idx = content.find('id="admin-home-settings-panel"')
        if start_idx == -1:
            print("Settings panel not found")
            return
            
        end_idx = content.find('<!-- PRODUCT LIST -->', start_idx)
        if end_idx == -1:
            end_idx = len(content)

        pre = content[:start_idx]
        post = content[end_idx:]
        panel = content[start_idx:end_idx]

        # Replace text inputs with drop zones
        def replacer(match):
            id_val = match.group(1)
            return f'''<div class="drop-zone" id="dz-{id_val}" data-target="{id_val}">
                  <img src="" class="preview-img" id="preview-{id_val}" />
                  <span class="drop-text">Drag & Drop or Click</span>
                  <input type="file" id="file-{id_val}" accept="image/*" />
                  <input type="hidden" id="{id_val}" />
                </div>'''

        panel = re.sub(
            r'<input type="text" id="(home-[^"]+)" placeholder="[^"]*" />',
            replacer,
            panel
        )

        with open('admin.html', 'w', encoding='utf-8') as f:
            f.write(pre + panel + post)

        print("Updated admin.html")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == '__main__':
    main()

