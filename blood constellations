    getContactInfo: function () {
      let info = localStorage.getItem('bc_contact_info');
      return info ? JSON.parse(info) : { mobile: '+1 (555) 019-2834' };
    },
    saveContactInfo: function (info) {
      localStorage.setItem('bc_contact_info', JSON.stringify(info));
      window.dispatchEvent(new Event('bc_contact_info_changed'));
    }
  };
})();

/* ==============================
   WAR OF BLOOD — CSS
   ============================== */

:root {
  --blood: #8B0000;
  --blood-bright: #CC0000;
  --blood-glow: #FF2222;
  --fire: #FF6B00;
  --fire-bright: #FF9500;
  --ember: #FFD700;
  --lightning: #7B5CFF;
  --lightning-bright: #AA88FF;
  --dark: #050508;
  --dark-2: #0D0D15;
  --dark-3: #12121E;
  --dark-4: #1A1A2E;
  --dark-5: #22223A;
  --text-primary: #F0EEE8;
  --text-secondary: #A09A8E;
  --text-muted: #5C5A52;
  --gold: #C9A84C;
  --gold-bright: #F0CC6E;
  --font-display: 'Cinzel Decorative', serif;
  --font-title: 'Cinzel', serif;
  --font-accent: 'Bebas Neue', sans-serif;
  --font-body: 'Inter', sans-serif;
  --ease-blood: cubic-bezier(0.25, 1, 0.5, 1);
  --ease-fire: cubic-bezier(0.34, 1.56, 0.64, 1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  overflow-x: hidden;
}

body {
  background: var(--dark);
  color: var(--text-primary);
  font-family: var(--font-body);
  overflow-x: hidden;
  cursor: default;
}

/* ==============================
   CUSTOM CURSOR
   ============================== */
body::after {
  content: '';
  position: fixed;
  width: 12px;
  height: 12px;
  background: var(--blood-bright);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%, -50%);
  transition: transform 0.1s;
  mix-blend-mode: screen;
  top: var(--cy, -100px);
  left: var(--cx, -100px);
}

/* ==============================
   INTRO SPLASH
   ============================== */
.intro-splash {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: #000;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.intro-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(139,0,0,0.15) 50%, rgba(0,0,0,0.9) 100%);
  z-index: 2;
}

.intro-slides {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.intro-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1.2s ease;
}

.intro-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transform: scale(1.08);
  transition: transform 4s ease;
  filter: brightness(0.55) saturate(1.4);
}

.intro-slide.active {
  opacity: 1;
}

.intro-slide.active img {
  transform: scale(1.0);
}

.slide-caption {
  position: absolute;
  bottom: 15%;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  z-index: 3;
  opacity: 0;
  animation: slideCaption 1s ease 0.8s forwards;
}

@keyframes slideCaption {
  from { opacity: 0; transform: translateX(-50%) translateY(20px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.slide-number {
  font-family: var(--font-accent);
  font-size: clamp(3rem, 8vw, 7rem);
  color: rgba(139,0,0,0.3);
  display: block;
  line-height: 1;
  letter-spacing: 0.2em;
}

.slide-caption p {
  font-family: var(--font-title);
  font-size: clamp(0.75rem, 2vw, 1.1rem);
  letter-spacing: 0.4em;
  color: rgba(240,238,232,0.6);
  text-transform: uppercase;
}

.intro-logo {
  position: relative;
  z-index: 5;
  text-align: center;
  pointer-events: none;
}

.blood-drip-container {
  position: absolute;
  top: -40px;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 20px;
}

.blood-drip {
  width: 3px;
  background: linear-gradient(to bottom, var(--blood-bright), transparent);
  border-radius: 0 0 2px 2px;
  animation: drip var(--dur, 1.5s) ease var(--delay, 0s) forwards;
  opacity: 0;
}

@keyframes drip {
  0% { height: 0; opacity: 0; transform: translateY(0); }
  10% { opacity: 1; }
  70% { height: var(--h, 40px); opacity: 1; }
  100% { height: var(--h, 40px); opacity: 0.6; transform: translateY(2px); }
}

.intro-title {
  font-family: var(--font-display);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  line-height: 0.9;
  user-select: none;
}

.war-text {
  font-size: clamp(4rem, 14vw, 11rem);
  color: var(--text-primary);
  letter-spacing: 0.15em;
  text-shadow:
    0 0 60px rgba(139,0,0,0.8),
    0 0 120px rgba(139,0,0,0.4),
    2px 2px 0 rgba(0,0,0,0.8);
  opacity: 0;
  transform: translateY(-30px);
  animation: fadeSlideDown 1s var(--ease-blood) 0.3s forwards;
}

.of-text {
  font-size: clamp(1.2rem, 3vw, 2.5rem);
  color: var(--gold);
  letter-spacing: 0.8em;
  text-transform: uppercase;
  opacity: 0;
  animation: fadeSlideDown 1s var(--ease-blood) 0.7s forwards;
  margin: 0.1em 0;
}

.blood-text {
  font-size: clamp(4rem, 14vw, 11rem);
  background: linear-gradient(135deg, var(--blood-bright) 0%, var(--blood) 40%, var(--fire) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 0.12em;
  text-shadow: none;
  filter: drop-shadow(0 0 30px var(--blood));
  opacity: 0;
  transform: translateY(30px);
  animation: fadeSlideUp 1s var(--ease-blood) 1s forwards;
}

@keyframes fadeSlideDown {
  from { opacity: 0; transform: translateY(-30px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
  from { opacity: 1; transform: translateY(30px); filter: drop-shadow(0 0 30px var(--blood)); }
  to { opacity: 1; transform: translateY(0); filter: drop-shadow(0 0 30px var(--blood)); }
}

.intro-tagline {
  font-family: var(--font-title);
  font-size: clamp(0.65rem, 1.5vw, 0.9rem);
  letter-spacing: 0.5em;
  color: var(--text-secondary);
  text-transform: uppercase;
  margin-top: 1.5rem;
  opacity: 0;
  animation: fadeIn 1s ease 1.8s forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

.skip-btn {
  position: absolute;
  bottom: 3rem;
  right: 3rem;
  z-index: 10;
  background: transparent;
  border: 1px solid rgba(139,0,0,0.5);
  color: var(--text-secondary);
  font-family: var(--font-accent);
  font-size: 0.85rem;
  letter-spacing: 0.25em;
  padding: 0.75rem 1.5rem;
  cursor: pointer;
  transition: all 0.3s ease;
  opacity: 0;
  animation: fadeIn 1s ease 2.2s forwards;
}

.skip-btn:hover {
  border-color: var(--blood-bright);
  color: var(--blood-bright);
  background: rgba(139,0,0,0.1);
}

.skip-btn span { margin-left: 0.5rem; }

.intro-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: rgba(255,255,255,0.05);
  z-index: 10;
}

.intro-progress-bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(to right, var(--blood), var(--fire));
  transition: width 0.1s linear;
}

/* ==============================
   MAIN SITE
   ============================== */
.main-site {
  opacity: 1;
  transition: opacity 0.8s ease;
}

.main-site.hidden {
  display: none;
  opacity: 0;
}

/* ==============================
   NAVBAR
   ============================== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 1.5rem 3rem;
  transition: all 0.4s ease;
  background: transparent;
}

.navbar.scrolled {
  padding: 1rem 3rem;
  background: rgba(5,5,8,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(139,0,0,0.2);
}

.nav-container {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo a {
  font-family: var(--font-accent);
  font-size: 1.6rem;
  letter-spacing: 0.1em;
  text-decoration: none;
  display: flex;
  gap: 0.2em;
}

.nav-logo-war { color: var(--text-primary); }
.nav-logo-of  { color: var(--gold); }
.nav-logo-blood { color: var(--blood-bright); }

.nav-links {
  display: flex;
  list-style: none;
  gap: 2.5rem;
  align-items: center;
}

.nav-link {
  font-family: var(--font-accent);
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  color: var(--text-secondary);
  text-decoration: none;
  position: relative;
  transition: color 0.3s;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--blood-bright);
  transition: width 0.3s ease;
}

.nav-link:hover { color: var(--text-primary); }
.nav-link:hover::after { width: 100%; }

.nav-link-cta {
  background: var(--blood);
  color: var(--text-primary) !important;
  padding: 0.5rem 1.25rem;
  border: 1px solid var(--blood-bright);
  letter-spacing: 0.15em;
}

.nav-link-cta:hover {
  background: var(--blood-bright) !important;
}

.nav-link-cta::after { display: none; }

.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 5px;
}

.nav-hamburger span {
  display: block;
  width: 25px;
  height: 2px;
  background: var(--text-primary);
  transition: all 0.3s;
}

@media (max-width: 900px) {
  .navbar { padding: 1.2rem 1.5rem; }
  .nav-hamburger { display: flex; }
  .nav-links {
    position: fixed;
    top: 0; right: -100%;
    width: 280px;
    height: 100vh;
    background: var(--dark-2);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    transition: right 0.4s ease;
    border-left: 1px solid rgba(139,0,0,0.3);
  }
  .nav-links.open { right: 0; }
  .nav-link { font-size: 1.2rem; }
}

/* ==============================
   HERO
   ============================== */
.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transform: scale(1.05);
  filter: brightness(0.35) saturate(1.3);
}

.hero-image-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-gradient-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at center top, rgba(139,0,0,0.25) 0%, transparent 60%),
    linear-gradient(to bottom, rgba(5,5,8,0.4) 0%, transparent 30%, transparent 60%, rgba(5,5,8,1) 100%),
    linear-gradient(to right, rgba(5,5,8,0.7) 0%, transparent 50%, rgba(5,5,8,0.7) 100%);
}

.hero-particle-field {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 900px;
  padding: 0 2rem;
}

.hero-eyebrow {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  color: var(--gold);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeSlideDown 0.8s ease 0.3s forwards;
}

.hero-title {
  font-family: var(--font-display);
  display: flex;
  flex-direction: column;
  line-height: 0.88;
  margin-bottom: 2rem;
}

.hero-war {
  font-size: clamp(5rem, 16vw, 13rem);
  color: var(--text-primary);
  text-shadow:
    0 0 80px rgba(139,0,0,0.6),
    0 0 200px rgba(139,0,0,0.2);
  opacity: 0;
  transform: translateX(-50px);
  animation: slideRight 1s var(--ease-blood) 0.5s forwards;
  letter-spacing: 0.1em;
}

.hero-of {
  font-family: var(--font-accent);
  font-size: clamp(1.2rem, 3vw, 2.2rem);
  color: var(--gold);
  letter-spacing: 1em;
  opacity: 0;
  animation: fadeIn 1s ease 0.9s forwards;
  margin: 0.1em 0;
}

.hero-blood {
  font-size: clamp(5rem, 16vw, 13rem);
  background: linear-gradient(135deg, #FF2222 0%, #8B0000 50%, #FF6B00 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 40px rgba(139,0,0,0.8));
  opacity: 0;
  transform: translateX(50px);
  animation: slideLeft 1s var(--ease-blood) 0.7s forwards;
  letter-spacing: 0.08em;
}

@keyframes slideRight {
  to { opacity: 1; transform: translateX(0); }
}

@keyframes slideLeft {
  to { opacity: 1; transform: translateX(0); }
}

.hero-subtitle {
  font-family: var(--font-title);
  font-size: clamp(0.85rem, 2vw, 1.15rem);
  color: var(--text-secondary);
  letter-spacing: 0.1em;
  margin-bottom: 3rem;
  opacity: 0;
  animation: fadeIn 1s ease 1.2s forwards;
}

.hero-cta-group {
  display: flex;
  gap: 1.25rem;
  justify-content: center;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeIn 1s ease 1.5s forwards;
}

.btn-primary {
  font-family: var(--font-accent);
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  color: var(--text-primary);
  background: var(--blood);
  border: 1px solid var(--blood-bright);
  padding: 1rem 2.5rem;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--blood-bright), var(--fire));
  opacity: 0;
  transition: opacity 0.3s;
}

.btn-primary:hover::before { opacity: 1; }
.btn-primary span, .btn-primary { z-index: 1; }
.btn-primary:hover {
  box-shadow: 0 0 30px rgba(139,0,0,0.6), 0 0 60px rgba(139,0,0,0.2);
  transform: translateY(-2px);
}

.btn-secondary {
  font-family: var(--font-accent);
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  color: var(--text-secondary);
  background: transparent;
  border: 1px solid rgba(160,154,142,0.3);
  padding: 1rem 2.5rem;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
}

.btn-secondary:hover {
  color: var(--text-primary);
  border-color: var(--text-secondary);
  transform: translateY(-2px);
}

.btn-outline {
  font-family: var(--font-accent);
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  color: var(--text-primary);
  background: transparent;
  border: 1px solid rgba(255,255,255,0.3);
  padding: 1rem 2.5rem;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
}

.btn-outline:hover {
  border-color: var(--text-primary);
  background: rgba(255,255,255,0.05);
  transform: translateY(-2px);
}

.hero-scroll-hint {
  position: absolute;
  bottom: -6rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  opacity: 0;
  animation: fadeIn 1s ease 2.5s forwards;
}

.scroll-line {
  width: 1px;
  height: 60px;
  background: linear-gradient(to bottom, transparent, var(--blood-bright), transparent);
  animation: scrollPulse 2s ease infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.hero-scroll-hint span {
  font-family: var(--font-accent);
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  color: var(--text-muted);
}

.hero-side-text {
  position: absolute;
  right: 2rem;
  top: 50%;
  transform: translateY(-50%) rotate(90deg);
  font-family: var(--font-accent);
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  color: var(--text-muted);
  z-index: 2;
  white-space: nowrap;
}

/* ==============================
   MARQUEE
   ============================== */
.marquee-strip {
  background: var(--blood);
  overflow: hidden;
  padding: 0.75rem 0;
  border-top: 1px solid rgba(255,0,0,0.2);
  border-bottom: 1px solid rgba(255,0,0,0.2);
}

.marquee-track {
  display: flex;
  gap: 2rem;
  width: max-content;
  animation: marquee 30s linear infinite;
  align-items: center;
}

.marquee-track span {
  font-family: var(--font-accent);
  font-size: 0.85rem;
  letter-spacing: 0.3em;
  color: rgba(255,255,255,0.85);
  white-space: nowrap;
}

.marquee-track .dot {
  color: rgba(255,255,255,0.4);
  font-size: 0.6rem;
}

@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

/* ==============================
   SECTION COMMONS
   ============================== */
.section-container {
  max-width: 1300px;
  margin: 0 auto;
  padding: 7rem 3rem;
}

.section-label {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  color: var(--blood-bright);
  margin-bottom: 1rem;
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 5rem);
  line-height: 1;
  color: var(--text-primary);
  margin-bottom: 5rem;
}

.highlight {
  background: linear-gradient(135deg, var(--blood-bright) 0%, var(--fire) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 20px rgba(139,0,0,0.5));
}

/* ==============================
   STORY SECTION
   ============================== */
.story-section {
  background: var(--dark-2);
  position: relative;
}

.story-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(139,0,0,0.5), transparent);
}

.story-blocks {
  display: flex;
  flex-direction: column;
  gap: 7rem;
}

.story-block {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.story-block.visible {
  opacity: 1;
  transform: translateY(0);
}

.story-block.reverse {
  direction: rtl;
}

.story-block.reverse > * {
  direction: ltr;
}

.story-image-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
}

.story-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform 0.8s ease;
  filter: saturate(1.2);
}

.story-image-wrap:hover .story-img {
  transform: scale(1.05);
}

.story-image-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 60%, rgba(5,5,8,0.8) 100%);
}

.story-image-number {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  font-family: var(--font-accent);
  font-size: 5rem;
  color: rgba(139,0,0,0.2);
  line-height: 1;
}

.story-text {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.story-chapter {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  color: var(--blood-bright);
}

.story-heading {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 3rem);
  color: var(--text-primary);
  line-height: 1.1;
}

.story-body {
  font-size: 1rem;
  line-height: 1.9;
  color: var(--text-secondary);
}

.story-quote {
  font-family: var(--font-title);
  font-style: italic;
  font-size: 1rem;
  color: var(--gold);
  border-left: 2px solid var(--blood);
  padding-left: 1.25rem;
  margin-top: 0.5rem;
}

@media (max-width: 900px) {
  .story-block {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .story-block.reverse { direction: ltr; }
}

/* ==============================
   CHARACTERS
   ============================== */
.characters-section {
  position: relative;
  background: var(--dark);
  overflow: hidden;
}

.char-bg-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(139,0,0,0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 50%, rgba(123,92,255,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.characters-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.char-card {
  background: var(--dark-3);
  border: 1px solid rgba(255,255,255,0.05);
  overflow: hidden;
  transition: transform 0.4s ease, border-color 0.4s ease;
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease, transform 0.7s ease, border-color 0.3s ease;
}

.char-card.visible {
  opacity: 1;
  transform: translateY(0);
}

.char-card:hover {
  border-color: rgba(139,0,0,0.4);
  transform: translateY(-8px);
}

.char-card.featured {
  border-color: rgba(139,0,0,0.3);
  position: relative;
}

.char-card.featured::before {
  content: 'ANTAGONIST';
  position: absolute;
  top: 1rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-accent);
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  color: var(--blood-bright);
  background: rgba(139,0,0,0.2);
  padding: 0.3rem 1rem;
  border: 1px solid rgba(139,0,0,0.3);
  z-index: 5;
  white-space: nowrap;
}

.char-image-wrap {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.char-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform 0.6s ease;
  filter: saturate(1.1);
}

.char-card:hover .char-img {
  transform: scale(1.05);
}

.char-img-fade {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 40%, var(--dark-3) 100%);
}

.char-power-badge {
  position: absolute;
  bottom: 1rem;
  right: 1rem;
  font-family: var(--font-accent);
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  padding: 0.3rem 0.75rem;
}

.char-power-badge.lightning {
  background: rgba(123,92,255,0.2);
  border: 1px solid rgba(123,92,255,0.4);
  color: var(--lightning-bright);
}

.char-power-badge.fire {
  background: rgba(255,107,0,0.2);
  border: 1px solid rgba(255,107,0,0.4);
  color: var(--fire-bright);
}

.char-power-badge.demon {
  background: rgba(139,0,0,0.3);
  border: 1px solid rgba(139,0,0,0.5);
  color: var(--blood-bright);
}

.char-info {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.char-role {
  font-family: var(--font-accent);
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  color: var(--text-muted);
}

.char-name {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  color: var(--text-primary);
  line-height: 1;
}

.char-desc {
  font-size: 0.85rem;
  line-height: 1.8;
  color: var(--text-secondary);
}

.char-stats {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-top: 0.5rem;
}

.stat {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.stat-label {
  font-family: var(--font-accent);
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  color: var(--text-muted);
  width: 70px;
  flex-shrink: 0;
}

.stat-bar {
  flex: 1;
  height: 3px;
  background: rgba(255,255,255,0.08);
  border-radius: 2px;
  overflow: hidden;
}

.stat-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(to right, var(--lightning), var(--lightning-bright));
  border-radius: 2px;
  transition: width 1.2s cubic-bezier(0.25, 1, 0.5, 1);
}

.stat-fill.fire-fill {
  background: linear-gradient(to right, var(--blood), var(--fire-bright));
}

.stat-fill.demon-fill {
  background: linear-gradient(to right, var(--blood), var(--blood-glow));
}

.stat-fill.animated {
  width: var(--fill);
}

@media (max-width: 900px) {
  .characters-grid {
    grid-template-columns: 1fr;
    max-width: 500px;
    margin: 0 auto;
  }
}

/* ==============================
   GALLERY
   ============================== */
.gallery-section {
  background: var(--dark-2);
}

.gallery-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: auto auto;
  gap: 1.5rem;
}

.gallery-item {
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.gallery-item.large {
  grid-row: 1 / 3;
}

.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  transition: transform 0.6s ease, filter 0.6s ease;
  filter: saturate(1.1) brightness(0.85);
  min-height: 250px;
}

.gallery-item:hover img {
  transform: scale(1.05);
  filter: saturate(1.3) brightness(1);
}

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
  display: flex;
  align-items: flex-end;
  padding: 1.5rem;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.gallery-item:hover .gallery-overlay { opacity: 1; }

.gallery-label {
  font-family: var(--font-accent);
  font-size: 0.8rem;
  letter-spacing: 0.3em;
  color: var(--text-primary);
}

@media (max-width: 700px) {
  .gallery-grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
  }
  .gallery-item.large { grid-row: auto; }
}

/* ==============================
   NEWS
   ============================== */
.news-section {
  background: var(--dark);
}

.news-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 2rem;
}

.news-card {
  background: var(--dark-3);
  border: 1px solid rgba(255,255,255,0.05);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

.news-card:hover {
  border-color: rgba(139,0,0,0.4);
  transform: translateY(-4px);
}

.news-card.featured-news {
  border-color: rgba(139,0,0,0.2);
  background: linear-gradient(135deg, var(--dark-3), rgba(139,0,0,0.05));
}

.news-tag {
  font-family: var(--font-accent);
  font-size: 0.65rem;
  letter-spacing: 0.4em;
  color: var(--blood-bright);
  display: inline-block;
}

.news-date {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.1em;
}

.news-title {
  font-family: var(--font-title);
  font-size: clamp(1rem, 2vw, 1.4rem);
  color: var(--text-primary);
  font-weight: 600;
  line-height: 1.3;
}

.news-excerpt {
  font-size: 0.875rem;
  line-height: 1.8;
  color: var(--text-secondary);
  flex: 1;
}

.news-link {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.2em;
  color: var(--blood-bright);
  text-decoration: none;
  transition: color 0.3s;
  margin-top: auto;
}

.news-link:hover { color: var(--fire); }

@media (max-width: 900px) {
  .news-grid { grid-template-columns: 1fr; }
}

/* ==============================
   BANNER CTA
   ============================== */
.banner-cta {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  inset: 0;
}

.banner-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  filter: brightness(0.25) saturate(1.5);
}

.banner-gradient {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at center, rgba(139,0,0,0.3) 0%, rgba(5,5,8,0.95) 70%),
    linear-gradient(to bottom, rgba(5,5,8,1) 0%, transparent 20%, transparent 80%, rgba(5,5,8,1) 100%);
}

.banner-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 800px;
  padding: 5rem 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.banner-eyebrow {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.5em;
  color: var(--blood-bright);
}

.banner-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  line-height: 1.1;
  color: var(--text-primary);
}

.banner-subtitle {
  font-size: 1rem;
  color: var(--text-secondary);
  max-width: 500px;
  line-height: 1.8;
}

.banner-cta-group {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 0.5rem;
}

.social-links {
  display: flex;
  gap: 1.5rem;
  margin-top: 1rem;
}

.social-link {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255,255,255,0.15);
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 1.1rem;
  transition: all 0.3s ease;
}

.social-link:hover {
  border-color: var(--blood-bright);
  color: var(--blood-bright);
  background: rgba(139,0,0,0.1);
}

/* ==============================
   FOOTER
   ============================== */
.footer {
  background: var(--dark-2);
  border-top: 1px solid rgba(255,255,255,0.05);
}

.footer-container {
  max-width: 1300px;
  margin: 0 auto;
  padding: 4rem 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  text-align: center;
}

.footer-logo {
  font-family: var(--font-accent);
  font-size: 2rem;
  letter-spacing: 0.15em;
}

.footer-tagline {
  font-family: var(--font-title);
  font-style: italic;
  color: var(--text-muted);
  font-size: 0.9rem;
  letter-spacing: 0.1em;
}

.footer-links {
  display: flex;
  list-style: none;
  gap: 2.5rem;
  flex-wrap: wrap;
  justify-content: center;
}

.footer-links a {
  font-family: var(--font-accent);
  font-size: 0.75rem;
  letter-spacing: 0.3em;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.3s;
}

.footer-links a:hover { color: var(--blood-bright); }

.footer-divider {
  width: 60px;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(139,0,0,0.5), transparent);
}

.footer-copy {
  font-size: 0.75rem;
  color: var(--text-muted);
  line-height: 1.8;
  max-width: 600px;
}

/* ==============================
   PARTICLES
   ============================== */
.particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: particleFloat var(--dur, 8s) ease-in-out var(--delay, 0s) infinite;
}

@keyframes particleFloat {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: var(--op, 0.5); }
  33% { transform: translate(var(--tx, 20px), var(--ty, -30px)) scale(1.2); }
  66% { transform: translate(var(--tx2, -10px), var(--ty2, -60px)) scale(0.8); opacity: 0; }
}

/* ==============================
   SCROLL REVEAL
   ============================== */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ==============================
   SECTION PADDING MOBILE
   ============================== */
@media (max-width: 700px) {
  .section-container { padding: 5rem 1.5rem; }
  .hero-side-text { display: none; }
  .skip-btn { bottom: 2rem; right: 1.5rem; }
  .banner-content { padding: 4rem 1.5rem; }
  .footer-container { padding: 3rem 1.5rem; }
  .footer-links { gap: 1.5rem; }
}

