// Administration Dashboard logic
(function () {
  'use strict';

  const loginGate = document.getElementById('admin-login-gate');
  const dashboard = document.getElementById('admin-dashboard');
  const loginForm = document.getElementById('login-form');
  const loginError = document.getElementById('login-error');
  const logoutBtn = document.getElementById('admin-logout-btn');

  // Stats
  const statProductsNum = document.getElementById('stat-products-num');
  const statOrdersNum = document.getElementById('stat-orders-num');
  const statRevenueNum = document.getElementById('stat-revenue-num');
  const statStockNum = document.getElementById('stat-stock-num');

  // Product Form
  const productForm = document.getElementById('product-form');
  const editIdInput = document.getElementById('edit-product-id');
  const titleInput = document.getElementById('product-title');
  const typeSelect = document.getElementById('product-type');
  const volumeInput = document.getElementById('product-volume');
  const priceInput = document.getElementById('product-price');
  const origPriceInput = document.getElementById('product-original-price');
  const descInput = document.getElementById('product-description');
  const stockInput = document.getElementById('product-stock');
  const pagesInput = document.getElementById('product-pages');
  const badgeInput = document.getElementById('product-badge');
  const featuredCheck = document.getElementById('product-featured');
  const formError = document.getElementById('form-error');
  const saveBtn = document.getElementById('save-product-btn');
  const cancelEditBtn = document.getElementById('cancel-edit-btn');
  const clearFormBtn = document.getElementById('clear-form-btn');
  const formPanelTitle = document.getElementById('form-panel-title');

  // Image Tabs
  const tabs = document.querySelectorAll('.image-tab');
  const tabContents = document.querySelectorAll('.image-tab-content');
  const imageUrlInput = document.getElementById('product-image-url');
  const imageUploadInput = document.getElementById('product-image-upload');
  const imageExistingSelect = document.getElementById('product-image-existing');
  const previewWrap = document.getElementById('image-preview-wrap');
  const previewImg = document.getElementById('image-preview');
  const removeImgBtn = document.getElementById('remove-image-btn');

  // List & Orders
  const productList = document.getElementById('admin-product-list');
  const productCountLabel = document.getElementById('product-count-label');
  const searchInput = document.getElementById('admin-search-input');
  const emptyProducts = document.getElementById('admin-empty-products');
  const ordersList = document.getElementById('orders-list');
  const emptyOrders = document.getElementById('admin-empty-orders');
  const clearOrdersBtn = document.getElementById('clear-orders-btn');

  let currentImage = '';
  let activeTab = 'url';

  // Authentication
  const AUTH_KEY = 'bc_admin_auth';
  const PASSWORD = 'bloodcons2026';

  function checkAuth() {
    if (sessionStorage.getItem(AUTH_KEY) === 'true') {
      loginGate.style.display = 'none';
      dashboard.style.display = 'block';
      initDashboard();
      if (typeof populateHomeSettings === 'function') {
        populateHomeSettings();
      }
      if (typeof renderAdminGallery === 'function') renderAdminGallery();
      if (typeof populateContactSettings === 'function') populateContactSettings();
    } else {
      loginGate.style.display = 'flex';
      dashboard.style.display = 'none';
    }
  }

  loginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const val = document.getElementById('admin-password').value;
    if (val === PASSWORD) {
      sessionStorage.setItem(AUTH_KEY, 'true');
      loginError.style.display = 'none';
      checkAuth();
    } else {
      loginError.style.display = 'block';
    }
  });

  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem(AUTH_KEY);
    checkAuth();
  });

  // Image input handling
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      const target = tab.dataset.tab;
      document.getElementById(`tab-content-${target}`).classList.add('active');
      activeTab = target;
    });
  });

  // Handle Existing Select
  imageExistingSelect.addEventListener('change', () => {
    if (imageExistingSelect.value) {
      setPreview(imageExistingSelect.value);
    }
  });

  // Handle Upload via server endpoint
  imageUploadInput.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (file) {
      if (!file.type.startsWith('image/')) {
        alert('Please upload an image file.');
        return;
      }
      try {
        const res = await fetch('/upload?filename=' + encodeURIComponent(file.name), {
          method: 'POST',
          body: file
        });
        const data = await res.json();
        if (data.success) {
          setPreview(data.path);
        } else {
          alert('Upload failed.');
        }
      } catch (err) {
        console.error('Upload error', err);
        // Fallback to base64 if upload fails
        const reader = new FileReader();
        reader.onload = function (evt) {
          setPreview(evt.target.result);
        };
        reader.readAsDataURL(file);
      }
    }
  });

  // Handle URL change
  imageUrlInput.addEventListener('input', () => {
    if (imageUrlInput.value) {
      setPreview(imageUrlInput.value);
    }
  });

  function setPreview(src) {
    currentImage = src;
    previewImg.src = src;
    previewWrap.style.display = 'flex';
  }

  removeImgBtn.addEventListener('click', () => {
    currentImage = '';
    previewImg.src = '';
    previewWrap.style.display = 'none';
    imageUploadInput.value = '';
    imageExistingSelect.value = '';
    imageUrlInput.value = '';
  });

  // Dashboard logic
  function initDashboard() {
    renderProducts();
    renderOrders();
    updateStats();
  }

  function updateStats() {
    const products = window.Store.getProducts();
    const orders = window.Store.getOrders();

    statProductsNum.textContent = products.length;
    statOrdersNum.textContent = orders.length;

    const totalStock = products.reduce((acc, p) => acc + parseInt(p.stock || 0), 0);
    statStockNum.textContent = totalStock;

    const rev = orders.reduce((acc, o) => acc + parseFloat(o.total || 0), 0);
    statRevenueNum.textContent = `₹${rev.toFixed(2)}`;
  }

  function renderProducts() {
    const products = window.Store.getProducts();
    const query = searchInput.value.toLowerCase();
    const filtered = products.filter(p => p.title.toLowerCase().includes(query) || p.description.toLowerCase().includes(query));

    productList.innerHTML = '';
    productCountLabel.textContent = `${filtered.length} items`;

    if (filtered.length === 0) {
      emptyProducts.style.display = 'block';
      return;
    }
    emptyProducts.style.display = 'none';

    filtered.forEach(p => {
      const item = document.createElement('div');
      item.classList.add('admin-product-item');
      item.innerHTML = `
        <img class="admin-product-thumb" src="${p.image || './images/hoodie_lightning.jpg'}" alt="" />
        <div class="admin-product-info">
          <div class="admin-product-title">${p.title}</div>
          <div class="admin-product-meta">
            Price: ₹${p.price} | Stock: ${p.stock} | Type: ${p.type.toUpperCase()}
          </div>
        </div>
        <div class="admin-product-actions">
          <button class="btn-edit-product" data-id="${p.id}">EDIT</button>
          <button class="btn-delete-product danger" data-id="${p.id}">DELETE</button>
        </div>
      `;
      productList.appendChild(item);
    });

    // Wire up buttons
    document.querySelectorAll('.btn-edit-product').forEach(btn => {
      btn.addEventListener('click', () => editProduct(btn.dataset.id));
    });
    document.querySelectorAll('.btn-delete-product').forEach(btn => {
      btn.addEventListener('click', () => deleteProduct(btn.dataset.id));
    });
  }

  searchInput.addEventListener('input', renderProducts);

  function editProduct(id) {
    const products = window.Store.getProducts();
    const p = products.find(x => x.id === id);
    if (!p) return;

    editIdInput.value = p.id;
    titleInput.value = p.title;
    typeSelect.value = p.type;
    volumeInput.value = p.volume || '';
    priceInput.value = p.price;
    origPriceInput.value = p.originalPrice || '';
    descInput.value = p.description;
    stockInput.value = p.stock;
    pagesInput.value = p.pages || '';
    badgeInput.value = p.badge || '';
    featuredCheck.checked = !!p.featured;

    if (p.image) {
      setPreview(p.image);
    } else {
      removeImgBtn.click();
    }

    formPanelTitle.textContent = '✏️ Edit Product';
    saveBtn.textContent = 'SAVE CHANGES';
    cancelEditBtn.style.display = 'inline-block';
    document.getElementById('admin-add-panel').scrollIntoView({ behavior: 'smooth' });
  }

  function deleteProduct(id) {
    if (confirm('Are you sure you want to delete this product?')) {
      let products = window.Store.getProducts();
      products = products.filter(p => p.id !== id);
      window.Store.saveProducts(products);
      initDashboard();
    }
  }

  function resetForm() {
    editIdInput.value = '';
    productForm.reset();
    removeImgBtn.click();
    formPanelTitle.textContent = '➕ Add New Product';
    saveBtn.textContent = '➕ ADD PRODUCT';
    cancelEditBtn.style.display = 'none';
  }

  cancelEditBtn.addEventListener('click', resetForm);
  clearFormBtn.addEventListener('click', resetForm);

  productForm.addEventListener('submit', (e) => {
    e.preventDefault();
    formError.textContent = '';

    if (!titleInput.value || !typeSelect.value || !priceInput.value || !descInput.value || stockInput.value === '') {
      formError.textContent = 'Please fill out all required fields.';
      return;
    }

    const products = window.Store.getProducts();
    const id = editIdInput.value || `product-${Date.now()}`;

    const newProduct = {
      id: id,
      title: titleInput.value,
      type: typeSelect.value,
      volume: volumeInput.value || null,
      price: parseFloat(priceInput.value),
      originalPrice: origPriceInput.value ? parseFloat(origPriceInput.value) : null,
      description: descInput.value,
      stock: parseInt(stockInput.value),
      pages: pagesInput.value ? parseInt(pagesInput.value) : null,
      image: currentImage || './images/hoodie_lightning.jpg',
      badge: badgeInput.value || null,
      featured: featuredCheck.checked
    };

    if (editIdInput.value) {
      const idx = products.findIndex(x => x.id === id);
      if (idx !== -1) products[idx] = newProduct;
    } else {
      products.push(newProduct);
    }

    window.Store.saveProducts(products);
    resetForm();
    initDashboard();
  });

  function renderOrders() {
    const orders = window.Store.getOrders();
    ordersList.innerHTML = '';

    if (orders.length === 0) {
      emptyOrders.style.display = 'block';
      clearOrdersBtn.style.display = 'none';
      return;
    }
    emptyOrders.style.display = 'none';
    clearOrdersBtn.style.display = 'inline-block';

